generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────

enum UserRole {
  super_admin
  site_admin
  field_coordinator
  operator
}

enum Language {
  en
  id
  ms
}

enum PatrolType {
  foot
  seaborne
}

enum PatrolState {
  open
  done
  cancelled
}

enum EventState {
  new_event
  active
  resolved
}

enum EventPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SyncType {
  events
  subjects
  patrols
  observations
  event_types
}

enum SyncStatus {
  running
  success
  failed
  partial
}

enum NotificationType {
  critical
  warning
  info
  system
}

enum RangerType {
  registered
  freetext
}

enum AccompanyingEntityType {
  event
  patrol
}

enum KnownRangerSource {
  earthranger_sync
  manual_entry
}

enum NotificationChannel {
  in_app
  email
}

enum BoundarySource {
  official
  custom
}

enum GeometryType {
  Polygon
  LineString
}

enum TrackSource {
  er_api
  cache
}

// ─────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────

model Tenant {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  isActive              Boolean  @default(true) @map("is_active")
  timezone              String   @default("UTC")
  syncFrequencySeconds  Int      @default(300) @map("sync_frequency_seconds")
  earthrangerUrl        String?  @map("earthranger_url")
  earthrangerUsername   String?  @map("earthranger_username")
  earthrangerPassword   String?  @map("earthranger_password")
  earthrangerDasToken   String?  @map("earthranger_das_token")
  earthrangerTrackToken String?  @map("earthranger_track_token")
  currency              String   @default("IDR")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  users               User[]
  events              Event[]
  eventTypes          EventType[]
  subjects            Subject[]
  subjectGroups       SubjectGroup[]
  patrols             Patrol[]
  observations        Observation[]
  patrolAreas         PatrolArea[]
  areaBoundaries      AreaBoundary[]
  patrolTracks        PatrolTrack[]
  alertRules          AlertRule[]
  alertHistory        AlertHistory[]
  notifications       Notification[]
  syncLogs            SyncLog[]
  auditLogs           AuditLog[]
  accompanyingRangers AccompanyingRanger[]
  knownRangers        KnownRanger[]
  patrolSchedules     PatrolSchedule[]

  @@map("tenants")
}

model User {
  id                 String    @id @default(cuid())
  tenantId           String?   @map("tenant_id")
  email              String    @unique
  passwordHash       String    @map("password_hash")
  fullName           String    @map("full_name")
  role               UserRole
  languagePreference Language  @default(en) @map("language_preference")
  isActive           Boolean   @default(true) @map("is_active")
  securityVersion    Int       @default(1) @map("security_version")
  lastLoginAt        DateTime? @map("last_login_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant                   Tenant?              @relation(fields: [tenantId], references: [id])
  notifications            Notification[]
  createdPatrolAreas       PatrolArea[]         @relation("PatrolAreaCreatedBy")
  createdAreaBoundaries    AreaBoundary[]       @relation("AreaBoundaryCreatedBy")
  createdAlertRules        AlertRule[]          @relation("AlertRuleCreatedBy")
  patrolSchedules          PatrolSchedule[]     @relation("PatrolScheduleRanger")
  createdPatrolSchedules   PatrolSchedule[]     @relation("PatrolScheduleCreatedBy")
  addedAccompanyingRangers AccompanyingRanger[] @relation("AccompanyingRangerAddedBy")
  registeredAsRanger       AccompanyingRanger[] @relation("AccompanyingRangerRegistered")
  auditLogs                AuditLog[]

  @@index([tenantId])
  @@map("users")
}

model EventType {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  erEventtypeId   String   @map("er_eventtype_id")
  value           String
  display         String
  category        String?
  defaultPriority Int      @default(0) @map("default_priority")
  iconId          String?  @map("icon_id")
  isActive        Boolean  @default(true) @map("is_active")
  schemaJson      Json?    @map("schema_json")
  syncedAt        DateTime @map("synced_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  events Event[]

  @@unique([tenantId, erEventtypeId])
  @@index([tenantId])
  @@map("event_types")
}

model Event {
  id               String     @id @default(cuid())
  tenantId         String     @map("tenant_id")
  erEventId        String     @map("er_event_id")
  eventTypeId      String?    @map("event_type_id")
  serialNumber     String?    @map("serial_number")
  title            String?
  priority         Int        @default(0)
  state            EventState @default(new_event)
  locationLat      Float?     @map("location_lat")
  locationLon      Float?     @map("location_lon")
  reportedByName   String?    @map("reported_by_name")
  reportedAt       DateTime?  @map("reported_at")
  eventDetailsJson Json?      @map("event_details_json")
  notesJson        Json?      @map("notes_json")
  syncedAt         DateTime   @map("synced_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  eventType           EventType?           @relation(fields: [eventTypeId], references: [id])
  notifications       Notification[]
  alertHistory        AlertHistory[]
  accompanyingRangers AccompanyingRanger[] @relation("AccompanyingRangerEvent")

  @@unique([tenantId, erEventId])
  @@index([tenantId])
  @@index([state])
  @@index([priority])
  @@map("events")
}

model Subject {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  erSubjectId     String    @map("er_subject_id")
  name            String
  subjectType     String?   @map("subject_type")
  subjectSubtype  String?   @map("subject_subtype")
  lastPositionLat Float?    @map("last_position_lat")
  lastPositionLon Float?    @map("last_position_lon")
  lastPositionAt  DateTime? @map("last_position_at")
  isActive        Boolean   @default(true) @map("is_active")
  additionalJson  Json?     @map("additional_json")
  groupId         String?   @map("group_id")
  syncedAt        DateTime  @map("synced_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  group        SubjectGroup? @relation(fields: [groupId], references: [id])
  observations Observation[]

  @@unique([tenantId, erSubjectId])
  @@index([tenantId])
  @@index([groupId])
  @@map("subjects")
}

model SubjectGroup {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  erGroupId    String   @map("er_group_id")
  name         String
  parentId     String?  @map("parent_id")
  subjectCount Int      @default(0) @map("subject_count")
  isVisible    Boolean  @default(true) @map("is_visible")
  syncedAt     DateTime @map("synced_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  parent   SubjectGroup?  @relation("SubjectGroupHierarchy", fields: [parentId], references: [id])
  children SubjectGroup[] @relation("SubjectGroupHierarchy")
  subjects Subject[]

  @@unique([tenantId, erGroupId])
  @@index([tenantId])
  @@index([parentId])
  @@map("subject_groups")
}

model Patrol {
  id              String      @id @default(cuid())
  tenantId        String      @map("tenant_id")
  erPatrolId      String      @map("er_patrol_id")
  serialNumber    String?     @map("serial_number")
  title           String?
  patrolType      PatrolType  @map("patrol_type")
  state           PatrolState @default(open)
  boatName        String?     @map("boat_name")
  startTime       DateTime?   @map("start_time")
  endTime         DateTime?   @map("end_time")
  totalDistanceKm Float?      @map("total_distance_km")
  totalHours      Float?      @map("total_hours")
  syncedAt        DateTime    @map("synced_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  segments            PatrolSegment[]
  accompanyingRangers AccompanyingRanger[] @relation("AccompanyingRangerPatrol")
  notifications       Notification[]
  track               PatrolTrack?

  @@unique([tenantId, erPatrolId])
  @@index([tenantId])
  @@index([state])
  @@map("patrols")
}

model PatrolSegment {
  id             String    @id @default(cuid())
  patrolId       String    @map("patrol_id")
  erSegmentId    String    @map("er_segment_id")
  scheduledStart DateTime? @map("scheduled_start")
  scheduledEnd   DateTime? @map("scheduled_end")
  actualStart    DateTime? @map("actual_start")
  actualEnd      DateTime? @map("actual_end")
  leaderName     String?   @map("leader_name")
  leaderErId     String?   @map("leader_er_id")
  syncedAt       DateTime  @map("synced_at")

  patrol Patrol @relation(fields: [patrolId], references: [id], onDelete: Cascade)

  @@unique([patrolId, erSegmentId])
  @@index([patrolId])
  @@map("patrol_segments")
}

model Observation {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  erObservationId String   @map("er_observation_id")
  subjectId       String?  @map("subject_id")
  locationLat     Float    @map("location_lat")
  locationLon     Float    @map("location_lon")
  recordedAt      DateTime @map("recorded_at")
  sourceName      String?  @map("source_name")
  additionalJson  Json?    @map("additional_json")
  syncedAt        DateTime @map("synced_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  subject Subject? @relation(fields: [subjectId], references: [id])

  @@unique([tenantId, erObservationId])
  @@index([tenantId])
  @@index([subjectId])
  @@map("observations")
}

model PatrolArea {
  id             String     @id @default(cuid())
  tenantId       String     @map("tenant_id")
  name           String
  description    String?
  patrolType     PatrolType @map("patrol_type")
  polygonGeojson Json       @map("polygon_geojson")
  colorHex       String     @map("color_hex")
  createdBy      String     @map("created_by")
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  creator   User             @relation("PatrolAreaCreatedBy", fields: [createdBy], references: [id])
  schedules PatrolSchedule[]

  @@index([tenantId])
  @@map("patrol_areas")
}

model AreaBoundary {
  id                String         @id @default(cuid())
  tenantId          String         @map("tenant_id")
  name              String
  aliases           String[]
  region            String
  source            BoundarySource @default(custom)
  geometryType      GeometryType   @map("geometry_type")
  geometryGeojson   Json           @map("geometry_geojson")
  isEnabled         Boolean        @default(true) @map("is_enabled")
  overrideOfficial  Boolean        @default(false) @map("override_official")
  arcgisReferenceId String?        @map("arcgis_reference_id")
  createdByUserId   String         @map("created_by_user_id")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  tenant  Tenant @relation(fields: [tenantId], references: [id])
  creator User   @relation("AreaBoundaryCreatedBy", fields: [createdByUserId], references: [id])

  @@index([tenantId])
  @@index([tenantId, isEnabled])
  @@map("area_boundaries")
}

model PatrolTrack {
  id             String      @id @default(cuid())
  tenantId       String      @map("tenant_id")
  patrolId       String      @unique @map("patrol_id")
  subjectId      String?     @map("subject_id")
  since          DateTime
  until          DateTime
  trackGeojson   Json        @map("track_geojson")
  hasTimestamps  Boolean     @default(false) @map("has_timestamps")
  pointCount     Int         @default(0) @map("point_count")
  lastTrackTime  DateTime?   @map("last_track_time")
  patrolEnded    Boolean     @default(false) @map("patrol_ended")
  source         TrackSource
  fetchedAt      DateTime    @map("fetched_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  patrol Patrol @relation(fields: [patrolId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, patrolEnded])
  @@map("patrol_tracks")
}

model PatrolSchedule {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  patrolAreaId   String   @map("patrol_area_id")
  rangerUserId   String?  @map("ranger_user_id")
  rangerName     String   @map("ranger_name")
  scheduledStart DateTime @map("scheduled_start")
  scheduledEnd   DateTime @map("scheduled_end")
  notes          String?
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  patrolArea PatrolArea @relation(fields: [patrolAreaId], references: [id], onDelete: Cascade)
  ranger     User?      @relation("PatrolScheduleRanger", fields: [rangerUserId], references: [id])
  creator    User       @relation("PatrolScheduleCreatedBy", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([patrolAreaId])
  @@index([rangerUserId])
  @@map("patrol_schedules")
}

model AlertRule {
  id                   String                @id @default(cuid())
  tenantId             String                @map("tenant_id")
  name                 String
  conditionJson        Json                  @map("condition_json")
  notificationChannels NotificationChannel[] @map("notification_channels")
  isActive             Boolean               @default(true) @map("is_active")
  createdBy            String                @map("created_by")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  creator       User           @relation("AlertRuleCreatedBy", fields: [createdBy], references: [id])
  notifications Notification[]
  history       AlertHistory[]

  @@index([tenantId])
  @@map("alert_rules")
}

model AlertHistory {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  alertRuleId        String?  @map("alert_rule_id")
  eventId            String?  @map("event_id")
  firedAt            DateTime @default(now()) @map("fired_at")
  matchedPriority    Int      @map("matched_priority")
  recipientCount     Int      @map("recipient_count")
  ruleNameSnapshot   String   @map("rule_name_snapshot")
  eventTitleSnapshot String   @map("event_title_snapshot")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  alertRule AlertRule? @relation(fields: [alertRuleId], references: [id], onDelete: SetNull)
  event     Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([alertRuleId])
  @@index([eventId])
  @@index([tenantId, firedAt])
  @@map("alert_history")
}

model Notification {
  id               String           @id @default(cuid())
  tenantId         String           @map("tenant_id")
  userId           String           @map("user_id")
  alertRuleId      String?          @map("alert_rule_id")
  eventId          String?          @map("event_id")
  patrolId         String?          @map("patrol_id")
  title            String
  message          String
  isRead           Boolean          @default(false) @map("is_read")
  notificationType NotificationType @map("notification_type")
  createdAt        DateTime         @default(now()) @map("created_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  user      User       @relation(fields: [userId], references: [id])
  alertRule AlertRule? @relation(fields: [alertRuleId], references: [id])
  event     Event?     @relation(fields: [eventId], references: [id])
  patrol    Patrol?    @relation(fields: [patrolId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
  @@index([patrolId])
  @@map("notifications")
}

model SyncLog {
  id            String     @id @default(cuid())
  tenantId      String     @map("tenant_id")
  syncType      SyncType   @map("sync_type")
  status        SyncStatus
  recordsSynced Int        @default(0) @map("records_synced")
  errorMessage  String?    @map("error_message")
  startedAt     DateTime   @map("started_at")
  completedAt   DateTime?  @map("completed_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([syncType])
  @@map("sync_logs")
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  userId      String   @map("user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  changesJson Json?    @map("changes_json")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model AccompanyingRanger {
  id               String                 @id @default(cuid())
  tenantId         String                 @map("tenant_id")
  entityType       AccompanyingEntityType @map("entity_type")
  entityId         String                 @map("entity_id")
  rangerType       RangerType             @map("ranger_type")
  registeredUserId String?                @map("registered_user_id")
  knownRangerId    String?                @map("known_ranger_id")
  freetextName     String?                @map("freetext_name")
  addedByUserId    String                 @map("added_by_user_id")
  createdAt        DateTime               @default(now()) @map("created_at")

  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  event          Event?       @relation("AccompanyingRangerEvent", fields: [entityId], references: [id], map: "accompanying_ranger_event_fk")
  patrol         Patrol?      @relation("AccompanyingRangerPatrol", fields: [entityId], references: [id], map: "accompanying_ranger_patrol_fk")
  registeredUser User?        @relation("AccompanyingRangerRegistered", fields: [registeredUserId], references: [id])
  knownRanger    KnownRanger? @relation(fields: [knownRangerId], references: [id])
  addedBy        User         @relation("AccompanyingRangerAddedBy", fields: [addedByUserId], references: [id])

  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([knownRangerId])
  @@map("accompanying_rangers")
}

model KnownRanger {
  id          String            @id @default(cuid())
  tenantId    String            @map("tenant_id")
  name        String
  source      KnownRangerSource
  erSubjectId String?           @map("er_subject_id")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  accompanyingRangers AccompanyingRanger[]

  @@unique([tenantId, erSubjectId])
  @@index([tenantId])
  @@map("known_rangers")
}
