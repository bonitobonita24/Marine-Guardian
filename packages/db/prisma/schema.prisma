generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────

enum Severity {
  info
  warning
  high
  critical
}

enum UserRole {
  super_admin
  site_admin
  field_coordinator
  operator
  // Read-only role (2026-07-05): can view ONLY Command Center (/dashboard) +
  // Interactive Report Map (/map). No mutations anywhere — deliberately
  // excluded from adminProcedure/coordinatorProcedure/operatorProcedure in
  // rbac.ts, so it is rejected by every tRPC mutation gated by those. Nav +
  // route-level gating live in sidebar.tsx + middleware.ts.
  viewer
  // Full-access role (2026-07-06): everything super_admin/site_admin can do
  // app-wide — included in adminProcedure/coordinatorProcedure/
  // operatorProcedure/reportGenerateProcedure in rbac.ts — EXCEPT
  // adding/managing user accounts (user.create/resetPassword/updateRole/
  // deactivate/activate), which stay gated to the separate
  // userManagementProcedure (super_admin + site_admin ONLY; administrator is
  // deliberately never added to it). Nav + route-level gating for /users
  // live in sidebar.tsx + middleware.ts.
  administrator
}

enum Language {
  en
  id
  ms
}

enum PatrolType {
  foot
  seaborne
}

enum PatrolState {
  open
  done
  cancelled
}

enum EventState {
  new_event
  active
  resolved
}

enum EventPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SyncType {
  events
  subjects
  patrols
  observations
  event_types
}

enum SyncStatus {
  running
  success
  failed
  partial
}

enum NotificationType {
  critical
  warning
  info
  system
}

enum RangerType {
  registered
  freetext
}

enum AccompanyingEntityType {
  event
  patrol
}

enum KnownRangerSource {
  earthranger_sync
  manual_entry
}

enum NotificationChannel {
  in_app
  email
}

enum NotificationEmailStatus {
  pending
  sent
  suppressed_by_cooldown
  digested
  failed
}

enum BoundarySource {
  official
  custom
}

enum GeometryType {
  Polygon
  LineString
}

enum TrackSource {
  er_api
  cache
}

enum ReportType {
  coverage
  area
  consolidated
  detailed
  rangers
  patrol_filtered
  report_map
}

enum PaperSize {
  A4
  Letter
  Legal
}

enum ReportExportStatus {
  queued
  rendering
  ready
  failed
}

// ─── V32.9 Compliance & Data Privacy (RA 10173 / NPC) ───────────────────────

/// Lawful basis for processing personal data under RA 10173 §12 / §13.
enum LawfulBasis {
  consent
  contract
  legal_obligation
  vital_interest
  public_authority
  legitimate_interest
}

/// Data-subject-request type — the six rights granted by RA 10173 §16 + §18.
enum DsrType {
  inform
  access
  rectify
  erasure
  object
  port
}

/// Lifecycle of a data-subject request.
enum DsrStatus {
  received
  in_progress
  completed
  rejected
}

/// Lifecycle of a personal-data-breach incident (NPC Circular 16-03).
enum BreachStatus {
  detected
  assessed
  notified
  reported
  closed
}

/// Severity of a personal-data breach.
enum BreachSeverity {
  low
  medium
  high
}

// ─────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────

model Tenant {
  id                      String   @id @default(cuid())
  name                    String
  slug                    String   @unique
  isActive                Boolean  @default(true) @map("is_active")
  timezone                String   @default("UTC")
  syncFrequencySeconds    Int      @default(300) @map("sync_frequency_seconds")
  earthrangerUrl          String?  @map("earthranger_url")
  earthrangerUsername     String?  @map("earthranger_username")
  earthrangerPassword     String?  @map("earthranger_password")
  earthrangerDasToken     String?  @map("earthranger_das_token")
  earthrangerTrackToken   String?  @map("earthranger_track_token")
  telegramChannelId       String?  @map("telegram_channel_id")
  currency                String   @default("IDR")
  arcgisBoundaryUrl       String?  @map("arcgis_boundary_url")
  arcgisBoundaryOutfields String?  @map("arcgis_boundary_outfields")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  users                 User[]
  events                Event[]
  eventTypes            EventType[]
  subjects              Subject[]
  subjectGroups         SubjectGroup[]
  patrols               Patrol[]
  observations          Observation[]
  patrolAreas           PatrolArea[]
  areaBoundaries        AreaBoundary[]
  patrolTracks          PatrolTrack[]
  alertRules            AlertRule[]
  alertHistory          AlertHistory[]
  notifications         Notification[]
  syncLogs              SyncLog[]
  auditLogs             AuditLog[]           @relation("AuditLogTenant")
  impersonatedAuditLogs AuditLog[]           @relation("AuditLogImpersonatedAsTenant")
  accompanyingRangers   AccompanyingRanger[]
  knownRangers          KnownRanger[]
  patrolSchedules       PatrolSchedule[]
  fuelEntries           FuelEntry[]
  reportExports         ReportExport[]
  erConnection          TenantErConnection?
  eventAssets           EventAsset[]

  // V32.9 compliance
  consentLogs               ConsentLog[]
  dataSubjectRequests       DataSubjectRequest[]
  breachNotificationRecords BreachNotificationRecord[]
  retentionPolicies         RetentionPolicy[]

  // municipality-coverage
  municipalities                Municipality[]
  protectedZones                ProtectedZone[]
  patrolCoveredZones            PatrolCoveredZone[]
  eventCoveredZones             EventCoveredZone[]
  municipalityBoundarySnapshots MunicipalityBoundarySnapshot[]

  reportTemplates ReportTemplate[]

  @@map("tenants")
}

/// Per-tenant EarthRanger connection — one row per tenant (unique on tenant_id).
/// The api_token column stores AES-256-GCM ciphertext (iv + authtag + encrypted),
/// encrypted/decrypted by the server-side encrypt()/decrypt() helpers from
/// @marine-guardian/db using ENCRYPTION_KEY. It is NEVER returned in plaintext to clients.
model TenantErConnection {
  id              String    @id @default(cuid())
  tenantId        String    @unique @map("tenant_id")
  baseUrl         String    @map("base_url")
  apiTokenEnc     String    @map("api_token_enc")
  status          String    @default("unchecked")
  lastValidatedAt DateTime? @map("last_validated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // ops-milestone-1 — per-tenant recurring ER sync toggle + interval
  // recurringEnabled: false by default (opt-in, gated on a verified connection)
  // intervalMs: min 60_000 (1 min), default 300_000 (5 min) per PRODUCT.md §Background Jobs
  recurringEnabled Boolean @default(false) @map("recurring_enabled")
  intervalMs       Int     @default(300000) @map("interval_ms")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_er_connections")
}

model User {
  id                          String    @id @default(cuid())
  tenantId                    String?   @map("tenant_id")
  email                       String    @unique
  passwordHash                String    @map("password_hash")
  fullName                    String    @map("full_name")
  role                        UserRole
  languagePreference          Language  @default(en) @map("language_preference")
  // Command Center map municipality preference (2026-07-04) — persists the
  // operator's last-selected CC map municipality filter so it restores across
  // refresh and re-login on any device. Nullable = "All municipalities" (no
  // filter). Soft reference to Municipality.id (no FK: keeps the migration
  // additive/minimal, mirrors other soft-reference id columns in this schema;
  // an invalid/stale id is treated as null by the client, never enforced here).
  commandCenterMunicipalityId String?   @map("command_center_municipality_id")
  isActive                    Boolean   @default(true) @map("is_active")
  securityVersion             Int       @default(1) @map("security_version")
  lastLoginAt                 DateTime? @map("last_login_at")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime  @updatedAt @map("updated_at")

  tenant                   Tenant?                 @relation(fields: [tenantId], references: [id])
  notificationRecipients   NotificationRecipient[]
  createdPatrolAreas       PatrolArea[]            @relation("PatrolAreaCreatedBy")
  createdAreaBoundaries    AreaBoundary[]          @relation("AreaBoundaryCreatedBy")
  createdAlertRules        AlertRule[]             @relation("AlertRuleCreatedBy")
  patrolSchedules          PatrolSchedule[]        @relation("PatrolScheduleRanger")
  createdPatrolSchedules   PatrolSchedule[]        @relation("PatrolScheduleCreatedBy")
  addedAccompanyingRangers AccompanyingRanger[]    @relation("AccompanyingRangerAddedBy")
  registeredAsRanger       AccompanyingRanger[]    @relation("AccompanyingRangerRegistered")
  auditLogs                AuditLog[]              @relation("AuditLogUser")
  actingAuditLogs          AuditLog[]              @relation("AuditLogActingUser")
  loggedFuelEntries        FuelEntry[]             @relation("FuelEntryLoggedBy")
  requestedReportExports   ReportExport[]          @relation("ReportExportRequestedBy")
  reportedEvents           Event[]                 @relation("EventReportedByUser")

  // V32.9 compliance
  consentLogs                 ConsentLog[]
  dataSubjectRequests         DataSubjectRequest[]
  breachNotificationsRecorded BreachNotificationRecord[] @relation("BreachRecordedBy")

  @@index([tenantId])
  @@map("users")
}

model EventType {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  erEventtypeId   String   @map("er_eventtype_id")
  value           String
  display         String
  category        String?
  defaultPriority Int      @default(0) @map("default_priority")
  iconId          String?  @map("icon_id")
  isActive        Boolean  @default(true) @map("is_active")
  schemaJson      Json?    @map("schema_json")
  syncedAt        DateTime @map("synced_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  events Event[]

  @@unique([tenantId, erEventtypeId])
  @@index([tenantId])
  @@map("event_types")
}

model Event {
  id                      String     @id @default(cuid())
  tenantId                String     @map("tenant_id")
  erEventId               String     @map("er_event_id")
  eventTypeId             String?    @map("event_type_id")
  serialNumber            String?    @map("serial_number")
  title                   String?
  priority                Int        @default(0)
  state                   EventState @default(new_event)
  locationLat             Float?     @map("location_lat")
  locationLon             Float?     @map("location_lon")
  reportedByName          String?    @map("reported_by_name")
  reportedAt              DateTime?  @map("reported_at")
  eventDetailsJson        Json?      @map("event_details_json")
  notesJson               Json?      @map("notes_json")
  areaName                String?    @map("area_name")
  areaBoundaryId          String?    @map("area_boundary_id")
  areaDerivedAt           DateTime?  @map("area_derived_at")
  endTime                 DateTime?  @map("end_time")
  hasPhoto                Boolean    @default(false) @map("has_photo")
  reportedByUserId        String?    @map("reported_by_user_id")
  reportedByKnownRangerId String?    @map("reported_by_known_ranger_id")
  offenderName            String?    @map("offender_name")
  vesselName              String?    @map("vessel_name")
  vesselRegistration      String?    @map("vessel_registration")
  address                 String?
  actionTaken             String?    @map("action_taken") @db.Text
  // ops-milestone-1 — immutable verbatim ER snapshot; set on first sync, NEVER overwritten.
  // erOriginalSnapshot: null until the first successful ER sync of this record.
  erOriginalSnapshot      Json?      @map("er_original_snapshot")

  // municipality-coverage — assigned asynchronously after sync
  municipalityId         String?   @map("municipality_id")
  municipalityAssignedAt DateTime? @map("municipality_assigned_at")

  // event-patrol-link — derived from patrol.patrol_segments[].events[].id on
  // every patrol sync (see syncPatrols in er-sync.processor.ts). Nullable:
  // an event may not (yet) belong to any patrol, or the linking patrol sync
  // may not have run yet. ALWAYS derived from the patrol side — never trust
  // an event-side back-reference from ER.
  patrolId String? @map("patrol_id")

  syncedAt  DateTime @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant                Tenant               @relation(fields: [tenantId], references: [id])
  eventType             EventType?           @relation(fields: [eventTypeId], references: [id])
  areaBoundary          AreaBoundary?        @relation(fields: [areaBoundaryId], references: [id])
  municipality          Municipality?        @relation(fields: [municipalityId], references: [id])
  reportedByUser        User?                @relation("EventReportedByUser", fields: [reportedByUserId], references: [id])
  reportedByKnownRanger KnownRanger?         @relation("EventReportedByKnownRanger", fields: [reportedByKnownRangerId], references: [id])
  patrol                Patrol?              @relation("PatrolEvents", fields: [patrolId], references: [id], onDelete: SetNull)
  notifications         Notification[]
  alertHistory          AlertHistory[]
  accompanyingRangers   AccompanyingRanger[] @relation("AccompanyingRangerEvent")
  revisions             EventRevision[]
  coveredZones          EventCoveredZone[]
  assets                EventAsset[]

  @@unique([tenantId, erEventId])
  @@index([tenantId])
  @@index([state])
  @@index([priority])
  @@index([tenantId, areaBoundaryId])
  @@index([tenantId, municipalityId])
  @@index([tenantId, reportedByUserId])
  @@index([tenantId, reportedByKnownRangerId])
  @@index([tenantId, patrolId])
  @@map("events")
}

model Subject {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  erSubjectId     String    @map("er_subject_id")
  name            String
  subjectType     String?   @map("subject_type")
  subjectSubtype  String?   @map("subject_subtype")
  lastPositionLat Float?    @map("last_position_lat")
  lastPositionLon Float?    @map("last_position_lon")
  lastPositionAt  DateTime? @map("last_position_at")
  isActive        Boolean   @default(true) @map("is_active")
  additionalJson  Json?     @map("additional_json")
  groupId         String?   @map("group_id")
  syncedAt        DateTime  @map("synced_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  group         SubjectGroup?  @relation(fields: [groupId], references: [id])
  observations  Observation[]
  notifications Notification[]

  @@unique([tenantId, erSubjectId])
  @@index([tenantId])
  @@index([groupId])
  @@map("subjects")
}

model SubjectGroup {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  erGroupId    String   @map("er_group_id")
  name         String
  parentId     String?  @map("parent_id")
  subjectCount Int      @default(0) @map("subject_count")
  isVisible    Boolean  @default(true) @map("is_visible")
  syncedAt     DateTime @map("synced_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  parent   SubjectGroup?  @relation("SubjectGroupHierarchy", fields: [parentId], references: [id])
  children SubjectGroup[] @relation("SubjectGroupHierarchy")
  subjects Subject[]

  @@unique([tenantId, erGroupId])
  @@index([tenantId])
  @@index([parentId])
  @@map("subject_groups")
}

model Patrol {
  id              String      @id @default(cuid())
  tenantId        String      @map("tenant_id")
  erPatrolId      String      @map("er_patrol_id")
  serialNumber    String?     @map("serial_number")
  title           String?
  patrolType      PatrolType  @map("patrol_type")
  state           PatrolState @default(open)
  boatName        String?     @map("boat_name")
  startTime       DateTime?   @map("start_time")
  endTime         DateTime?   @map("end_time")
  totalDistanceKm Float?      @map("total_distance_km")
  totalHours      Float?      @map("total_hours")
  areaName        String?     @map("area_name")
  areaBoundaryId  String?     @map("area_boundary_id")
  areaDerivedAt   DateTime?   @map("area_derived_at")

  // v2 — location pairs (derived from first/last track point or segment start/end_location)
  startLocationLat Float? @map("start_location_lat")
  startLocationLon Float? @map("start_location_lon")
  endLocationLat   Float? @map("end_location_lat")
  endLocationLon   Float? @map("end_location_lon")

  // v2 — computed metrics (recomputed from PatrolTrack; preferred over ER totals in reports)
  computedDistanceKm    Float? @map("computed_distance_km")
  computedDurationHours Float? @map("computed_duration_hours")

  // v2 — flags
  isTestPatrol Boolean   @default(false) @map("is_test_patrol")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at")

  // v2 — sync-engine state (drives Active Check candidate selection per spec §Sync Engine)
  syncNeeded   Boolean   @default(false) @map("sync_needed")
  firstSeenAt  DateTime? @map("first_seen_at")
  lastSyncedAt DateTime? @map("last_synced_at")

  // ops-milestone-1 — immutable verbatim ER snapshot; set on first sync, NEVER overwritten.
  erOriginalSnapshot Json? @map("er_original_snapshot")

  // municipality-coverage — assigned asynchronously after patrol-track materializes
  municipalityId         String?   @map("municipality_id")
  municipalityAssignedAt DateTime? @map("municipality_assigned_at")

  syncedAt  DateTime @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  areaBoundary        AreaBoundary?        @relation(fields: [areaBoundaryId], references: [id])
  municipality        Municipality?        @relation(fields: [municipalityId], references: [id])
  segments            PatrolSegment[]
  accompanyingRangers AccompanyingRanger[] @relation("AccompanyingRangerPatrol")
  notifications       Notification[]
  track               PatrolTrack?
  revisions           PatrolRevision[]
  coveredZones        PatrolCoveredZone[]
  // event-patrol-link — events surfaced via patrol.patrol_segments[].events[]
  // on every ER patrol sync (see syncPatrols in er-sync.processor.ts).
  events              Event[]              @relation("PatrolEvents")

  @@unique([tenantId, erPatrolId])
  @@index([tenantId])
  @@index([state])
  @@index([tenantId, areaBoundaryId])
  @@index([tenantId, municipalityId])
  @@index([tenantId, syncNeeded, lastSyncedAt])
  @@index([tenantId, isDeleted])
  @@index([tenantId, isTestPatrol])
  @@map("patrols")
}

model PatrolSegment {
  id             String    @id @default(cuid())
  patrolId       String    @map("patrol_id")
  erSegmentId    String    @map("er_segment_id")
  scheduledStart DateTime? @map("scheduled_start")
  scheduledEnd   DateTime? @map("scheduled_end")
  actualStart    DateTime? @map("actual_start")
  actualEnd      DateTime? @map("actual_end")
  leaderName     String?   @map("leader_name")
  leaderErId     String?   @map("leader_er_id")
  syncedAt       DateTime  @map("synced_at")

  patrol Patrol @relation(fields: [patrolId], references: [id], onDelete: Cascade)

  @@unique([patrolId, erSegmentId])
  @@index([patrolId])
  @@map("patrol_segments")
}

model Observation {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  erObservationId String   @map("er_observation_id")
  subjectId       String?  @map("subject_id")
  locationLat     Float    @map("location_lat")
  locationLon     Float    @map("location_lon")
  recordedAt      DateTime @map("recorded_at")
  sourceName      String?  @map("source_name")
  additionalJson  Json?    @map("additional_json")
  syncedAt        DateTime @map("synced_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  subject Subject? @relation(fields: [subjectId], references: [id])

  @@unique([tenantId, erObservationId])
  @@index([tenantId])
  @@index([subjectId])
  @@map("observations")
}

model PatrolArea {
  id             String     @id @default(cuid())
  tenantId       String     @map("tenant_id")
  name           String
  description    String?
  patrolType     PatrolType @map("patrol_type")
  polygonGeojson Json       @map("polygon_geojson")
  colorHex       String     @map("color_hex")
  createdBy      String     @map("created_by")
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  creator   User             @relation("PatrolAreaCreatedBy", fields: [createdBy], references: [id])
  schedules PatrolSchedule[]

  @@index([tenantId])
  @@map("patrol_areas")
}

model AreaBoundary {
  id                String         @id @default(cuid())
  tenantId          String         @map("tenant_id")
  name              String
  aliases           String[]
  region            String
  source            BoundarySource @default(custom)
  geometryType      GeometryType   @map("geometry_type")
  geometryGeojson   Json           @map("geometry_geojson")
  isEnabled         Boolean        @default(true) @map("is_enabled")
  overrideOfficial  Boolean        @default(false) @map("override_official")
  arcgisReferenceId String?        @map("arcgis_reference_id")
  createdByUserId   String         @map("created_by_user_id")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  creator     User        @relation("AreaBoundaryCreatedBy", fields: [createdByUserId], references: [id])
  fuelEntries FuelEntry[]
  events      Event[]
  patrols     Patrol[]

  @@index([tenantId])
  @@index([tenantId, isEnabled])
  @@map("area_boundaries")
}

model PatrolTrack {
  id            String      @id @default(cuid())
  tenantId      String      @map("tenant_id")
  patrolId      String      @unique @map("patrol_id")
  subjectId     String?     @map("subject_id")
  since         DateTime
  until         DateTime
  trackGeojson  Json        @map("track_geojson")
  hasTimestamps Boolean     @default(false) @map("has_timestamps")
  pointCount    Int         @default(0) @map("point_count")
  lastTrackTime DateTime?   @map("last_track_time")
  patrolEnded   Boolean     @default(false) @map("patrol_ended")
  source        TrackSource
  fetchedAt     DateTime    @map("fetched_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  patrol Patrol @relation(fields: [patrolId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, patrolEnded])
  @@map("patrol_tracks")
}

model FuelEntry {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  areaName        String   @map("area_name")
  areaBoundaryId  String?  @map("area_boundary_id")
  // Kept in addition to areaBoundaryId (legacy/back-compat — not dropped).
  // Going forward this is the FK the create-fuel-entry dialog writes;
  // areaName stores the selected municipality's name as the display snapshot.
  municipalityId  String?  @map("municipality_id")
  dateReceived    DateTime @map("date_received") @db.Date
  liters          Decimal  @db.Decimal(12, 3)
  totalPrice      Decimal  @map("total_price") @db.Decimal(14, 2)
  currency        String
  receiptPhotoUrl String?  @map("receipt_photo_url")
  notes           String?
  loggedByUserId  String   @map("logged_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  areaBoundary AreaBoundary? @relation(fields: [areaBoundaryId], references: [id], onDelete: SetNull)
  municipality Municipality? @relation(fields: [municipalityId], references: [id], onDelete: SetNull)
  loggedBy     User          @relation("FuelEntryLoggedBy", fields: [loggedByUserId], references: [id])

  @@index([tenantId])
  @@index([tenantId, dateReceived])
  @@index([tenantId, areaBoundaryId])
  @@index([tenantId, municipalityId])
  @@map("fuel_entries")
}

model ReportExport {
  id                String             @id @default(cuid())
  tenantId          String             @map("tenant_id")
  requestedByUserId String             @map("requested_by_user_id")
  reportType        ReportType         @map("report_type")
  paramsJson        Json               @map("params_json")
  paperSize         PaperSize          @default(A4) @map("paper_size")
  status            ReportExportStatus @default(queued)
  filePath          String?            @map("file_path")
  telegramFileId    String?            @map("telegram_file_id")
  fileSizeBytes     Int?               @map("file_size_bytes")
  errorMessage      String?            @map("error_message")
  createdAt         DateTime           @default(now()) @map("created_at")
  completedAt       DateTime?          @map("completed_at")

  /// On-demand PDF→PowerPoint rendering. Independent of the PDF status
  /// columns above — a row can be status=ready (PDF) with pptxStatus=null
  /// (never requested), or any ReportExportStatus value once a "Render to
  /// PowerPoint" request has been made. Same Telegram-only storage contract
  /// as the PDF: pptxTelegramFileId is the sole store — no server-side/MinIO
  /// copy of the .pptx exists at any point.
  pptxStatus         ReportExportStatus? @map("pptx_status")
  pptxTelegramFileId String?             @map("pptx_telegram_file_id")
  pptxFileSizeBytes  Int?                @map("pptx_file_size_bytes")
  pptxErrorMessage   String?             @map("pptx_error_message")

  tenant      Tenant @relation(fields: [tenantId], references: [id])
  requestedBy User   @relation("ReportExportRequestedBy", fields: [requestedByUserId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("report_exports")
}

model PatrolSchedule {
