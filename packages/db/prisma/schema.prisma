model AccompanyingRanger {
  id               String                 @id @default(cuid())
  tenantId         String                 @map("tenant_id")
  entityType       AccompanyingEntityType @map("entity_type")
  entityId         String                 @map("entity_id")
  rangerType       RangerType             @map("ranger_type")
  registeredUserId String?                @map("registered_user_id")
  knownRangerId    String?                @map("known_ranger_id")
  freetextName     String?                @map("freetext_name")
  addedByUserId    String                 @map("added_by_user_id")
  createdAt        DateTime               @default(now()) @map("created_at")

  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  // POLYMORPHIC ASSOCIATION — `entityId` points at EITHER an event OR a patrol
  // depending on `entityType`. The two DB-level foreign keys these relations
  // would generate are intentionally DROPPED by migration
  // `20260619000000_drop_polymorphic_accompanying_ranger_fks` because a single
  // column cannot satisfy two mandatory cross-table FKs at once (it caused a
  // 23503 violation / 500 on every insert). Referential integrity for
  // `entityId` is enforced in the tRPC mutations (parent existence + tenant
  // scope are checked before insert). If you ever run `prisma migrate dev`,
  // KEEP that drop migration — do not let Prisma re-add these constraints.
  event          Event?       @relation("AccompanyingRangerEvent", fields: [entityId], references: [id], map: "accompanying_ranger_event_fk")
  patrol         Patrol?      @relation("AccompanyingRangerPatrol", fields: [entityId], references: [id], map: "accompanying_ranger_patrol_fk")
  registeredUser User?        @relation("AccompanyingRangerRegistered", fields: [registeredUserId], references: [id])
  knownRanger    KnownRanger? @relation(fields: [knownRangerId], references: [id])
  addedBy        User         @relation("AccompanyingRangerAddedBy", fields: [addedByUserId], references: [id])

  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([knownRangerId])
  @@map("accompanying_rangers")
}

model KnownRanger {
  id          String            @id @default(cuid())
  tenantId    String            @map("tenant_id")
  name        String
  source      KnownRangerSource
  erSubjectId String?           @map("er_subject_id")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  accompanyingRangers AccompanyingRanger[]
  reportedEvents      Event[]              @relation("EventReportedByKnownRanger")

  @@unique([tenantId, erSubjectId])
  @@index([tenantId])
  @@map("known_rangers")
}

// ─────────────────────────────────────────────────
// V32.9 COMPLIANCE & DATA PRIVACY MODELS (RA 10173 / NPC)
// All tenant-scoped (shared-schema multi-tenancy + tenant_id, L6 guardrails).
// ─────────────────────────────────────────────────

/// Consent ledger — records grant/withdrawal of consent for a processing
/// purpose (RA 10173 §3(b), §12(a)). Marine Guardian processes very little
/// consent-based data today (lawful basis is mostly contract / legitimate
/// interest for conservation operations), but the ledger exists so any future
/// consent-based purpose has an audit trail.
model ConsentLog {
  id            String      @id @default(cuid())
  tenantId      String      @map("tenant_id")
  userId        String      @map("user_id")
  /// Processing activity being consented to (e.g. "patrol-location-sharing").
  purpose       String
  lawfulBasis   LawfulBasis @map("lawful_basis")
  /// Version of the privacy notice shown at grant time.
  noticeVersion String      @map("notice_version")
  granted       Boolean
  grantedAt     DateTime    @default(now()) @map("granted_at")
  withdrawnAt   DateTime?   @map("withdrawn_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@map("consent_logs")
}

/// Data-subject request register — every RA 10173 §16 right exercised by a
/// user against their own personal data, with the statutory response clock.
model DataSubjectRequest {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  userId      String    @map("user_id")
  type        DsrType   @map("type")
  status      DsrStatus @default(received) @map("status")
  requestedAt DateTime  @default(now()) @map("requested_at")
  /// Statutory response window: 15 calendar days from receipt (owner-ratified
  /// 2026-06-21; NPC reasonable-period guidance — adjust per future advisory).
  dueAt       DateTime  @map("due_at")
  resolvedAt  DateTime? @map("resolved_at")
  /// URL/reference to the export artifact or action record (e.g. signed S3 URL
  /// for a PORT export). Null for actions with no downloadable artifact.
  evidenceUrl String?   @map("evidence_url")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@map("data_subject_requests")
}

/// Personal-data-breach register — NPC Circular 16-03 lifecycle + statutory
/// deadlines. writtenReportDueAt is pre-computed at creation as
/// detectedAt + 72h + 5 business days so SLA dashboards query cheaply.
model BreachNotificationRecord {
  id                       String         @id @default(cuid())
  tenantId                 String         @map("tenant_id")
  severity                 BreachSeverity
  status                   BreachStatus   @default(detected)
  detectedAt               DateTime       @map("detected_at")
  /// 72h NPC notification deadline + 5 business days written-report deadline.
  writtenReportDueAt       DateTime       @map("written_report_due_at")
  npcNotifiedAt            DateTime?      @map("npc_notified_at")
  subjectsNotifiedAt       DateTime?      @map("subjects_notified_at")
  writtenReportSubmittedAt DateTime?      @map("written_report_submitted_at")
  affectedUserCount        Int            @default(0) @map("affected_user_count")
  description              String         @db.Text
  recordedByUserId         String         @map("recorded_by_user_id")
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  recordedBy User   @relation("BreachRecordedBy", fields: [recordedByUserId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, detectedAt])
  @@map("breach_notification_records")
}

/// Retention-policy register — declares how long each category of personal data
/// is kept (RA 10173 §11(e) storage-limitation + §19 disposal). Owner-ratified
/// 2026-06-21: audit logs 5y · general operational/patrol/observation data 3y.
/// (Marine Guardian has no payroll/financial 7y category.)
model RetentionPolicy {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  /// Data category, e.g. "audit_logs", "patrol_records", "observation_data".
  dataCategory    String   @map("data_category")
  retentionMonths Int      @map("retention_months")
  /// Statutory / operational justification for the retention period.
  basis           String   @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, dataCategory])
  @@index([tenantId])
  @@map("retention_policies")
}

// ── Municipality Coverage (V32.12 feature) ───────────────────────────────────

/// Canonical municipality record seeded from GeoJSON polygons.
/// One row per LGU per tenant (upserted from coverage-areas.ts on deploy).
model Municipality {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  slug            String // e.g. "calapan-city"
  name            String
  province        String
  psgcCode        String?  @map("psgc_code")
  boundaryGeojson Json     @map("boundary_geojson")
  // Derived ~15 km municipal-water polygon (land ∪ 15 km seaward buffer minus all
  // land). Null until seed-municipalities loads it from data/coverage/water/.
  waterGeojson    Json?    @map("water_geojson")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant            Tenant                          @relation(fields: [tenantId], references: [id])
  patrols           Patrol[]
  events            Event[]
  protectedZones    ProtectedZone[]
  fuelEntries       FuelEntry[]
  boundarySnapshots MunicipalityBoundarySnapshot[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("municipalities")
}

/// Snapshot of a municipality's prior land/water geometry, written immediately
/// before a boundary-geometry replace so the previous polygon can be restored.
model MunicipalityBoundarySnapshot {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  municipalityId   String   @map("municipality_id")
  kind             String   // "land" | "water"
  previousGeojson  Json?    @map("previous_geojson")
  replacedByUserId String?  @map("replaced_by_user_id")
  label            String?
  createdAt        DateTime @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  municipality Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)

  @@index([tenantId, municipalityId, kind, createdAt])
  @@map("municipality_boundary_snapshots")
}

/// Protected zone (marine park, natural park, etc.) — many-to-many via
/// PatrolCoveredZone / EventCoveredZone. A zone may belong to a parent
/// municipality (e.g. Apo Reef → Sablayan).
model ProtectedZone {
  id                   String   @id @default(cuid())
  tenantId             String   @map("tenant_id")
  slug                 String // e.g. "apo-reef-natural-park"
  name                 String
  // Sub-area category for user-uploaded zones: "mpa" (Marine Protected Area) or
  // "special_area" (a named sub-boundary under a municipality). Seeded MPAs and
  // legacy rows default to "mpa". Both behave identically (filterable coverage
  // zone) — this drives only the label shown in the UI.
  category             String   @default("mpa") @map("category")
  boundaryGeojson      Json     @map("boundary_geojson")
  // Terrain classifier for the single boundaryGeojson geometry above: "land" or
  // "water". Existing zones default to "land". Replaces the short-lived
  // water_geojson dual-geometry column (20260708210000).
  terrain              String   @default("land") @map("terrain")
  parentMunicipalityId String?  @map("parent_municipality_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  parentMunicipality Municipality?       @relation(fields: [parentMunicipalityId], references: [id])
  patrolZones        PatrolCoveredZone[]
  eventZones         EventCoveredZone[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("protected_zones")
}

/// Junction: which patrol covered which protected zone (derived from track).
model PatrolCoveredZone {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  patrolId        String   @map("patrol_id")
  protectedZoneId String   @map("protected_zone_id")
  assignedAt      DateTime @default(now()) @map("assigned_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  patrol        Patrol        @relation(fields: [patrolId], references: [id])
  protectedZone ProtectedZone @relation(fields: [protectedZoneId], references: [id])

  @@unique([patrolId, protectedZoneId])
  @@index([tenantId])
  @@map("patrol_covered_zones")
}

/// Junction: which event occurred within which protected zone (derived from lat/lon).
model EventCoveredZone {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  eventId         String   @map("event_id")
  protectedZoneId String   @map("protected_zone_id")
  assignedAt      DateTime @default(now()) @map("assigned_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  event         Event         @relation(fields: [eventId], references: [id])
  protectedZone ProtectedZone @relation(fields: [protectedZoneId], references: [id])

  @@unique([eventId, protectedZoneId])
  @@index([tenantId])
  @@map("event_covered_zones")
}

// EarthRanger event attachment archived to Telegram (per-tenant channel).
// Records where each ER file (er_file_id) now lives in Telegram so the app can
// fetch it back via the bot. uploaded_at null = recorded but not yet pushed.
model EventAsset {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  eventId           String    @map("event_id")
  erFileId          String    @map("er_file_id")
  filename          String
  fileType          String?   @map("file_type")
  mimeType          String?   @map("mime_type")
  sizeBytes         Int?      @map("size_bytes")
  telegramMessageId BigInt?   @map("telegram_message_id")
  telegramFileId    String?   @map("telegram_file_id")
  uploadedAt        DateTime? @map("uploaded_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  event  Event  @relation(fields: [eventId], references: [id])

  @@unique([tenantId, erFileId])
  @@index([tenantId])
  @@index([eventId])
  @@map("event_assets")
}

model ReportTemplate {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  name             String
  layout           String
  municipalLogoKey String?  @map("municipal_logo_key")
  partnerLogoKey   String?  @map("partner_logo_key")
  reportTitle      String   @map("report_title")
  footerNotes      String?  @map("footer_notes")
  isDefault        Boolean  @default(false) @map("is_default")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, isDefault])
  @@map("report_templates")
}
