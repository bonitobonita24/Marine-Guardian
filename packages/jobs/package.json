{
  "name": "@marine-guardian/jobs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./queues": "./src/queues/index.ts",
    "./workers": "./src/workers/index.ts",
    "./connection": "./src/connection.ts"
  },
  "scripts": {
    "build": "esbuild src/start-workers.ts --bundle --platform=node --format=esm --outfile=dist/start-workers.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\" --external:child_process --external:fs --external:path --external:os --external:net --external:tls --external:dns --external:crypto --external:stream --external:events --external:util --external:assert --external:http --external:https --external:zlib --external:url --external:querystring --external:string_decoder --external:buffer --external:worker_threads --external:cluster --external:dgram --external:readline",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@marine-guardian/db": "workspace:*",
    "@prisma/client": "^6.8.0",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "esbuild": ">=0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
