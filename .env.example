# ═══════════════════════════════════════════════════════════════════
# Marine Guardian — Command Center — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
# HOW TO USE:
# 1. Copy this file: cp .env.example .env.dev
# 2. Fill in real values (or run Phase 3 to auto-generate them)
# 3. NEVER commit .env.dev, .env.staging, or .env.prod to git
# 4. NEVER commit CREDENTIALS.md to git (it is gitignored)
#
# FIRST ADMIN ACCOUNT (created by pnpm db:seed):
#   Username: webmaster
#   Password: see CREDENTIALS.md (gitignored — generated by Phase 3)
#   URL: http://localhost:[APP_PORT]/login
#
# All service passwords in CREDENTIALS.md are AI-generated strong passwords.
# Anyone cloning this repo must generate their own via Phase 3.
# ═══════════════════════════════════════════════════════════════════
COMPOSE_PROJECT_NAME=marine-guardian_dev
APP_ENV=development|staging|production
APP_PORT=3000

# DOCKER HUB IMAGE (staging/prod only)
# APP_IMAGE_TAG=staging-latest
# PDF_IMAGE_TAG=staging-latest   # pdf-renderer image tag (marine-guardian-pdf)
# DOCKERHUB_USERNAME=your-dockerhub-username
# IMAGE_NAME=marine-guardian

# TRAEFIK (staging/prod only)
# TRAEFIK_NETWORK=proxy
# APP_DOMAIN=your-app-domain.example.com

# DATABASE
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marine-guardian_dev
DB_USER=marine-guardian_your-hex-suffix
DB_PASSWORD=your-db-password-here
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# PGBOUNCER
PGBOUNCER_PORT=6432
PGBOUNCER_AUTH_PASSWORD=your-pgbouncer-password-here
PGBOUNCER_DATABASE_URL=postgresql://${DB_USER}:${PGBOUNCER_AUTH_PASSWORD}@localhost:${PGBOUNCER_PORT}/${DB_NAME}

# CACHE
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# FILE STORAGE (MinIO — S3-compatible, MinIO-per-stack: own container per env)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_CONSOLE_PORT=9001
STORAGE_BUCKET=marine-guardian-dev
STORAGE_ACCESS_KEY=marine-guardian-your-hex-suffix
STORAGE_SECRET_KEY=your-storage-secret-key-here
STORAGE_REGION=us-east-1
# INTERNAL STORAGE ENDPOINT (staging/prod only — Docker network alias for the
# app + worker containers; STORAGE_ENDPOINT above is for host-side mc tools).
# Hyphenated host (minio-stage / minio-prod) — AWS S3 SDK rejects underscores.
# INTERNAL_STORAGE_ENDPOINT=http://minio-prod:9000

# AUTH
AUTH_SECRET=your-48-char-auth-secret-here
NEXTAUTH_URL=http://localhost:${APP_PORT}
# Required when running behind a reverse proxy (Traefik/Nginx) — tells Auth.js
# to trust the forwarded Host header so /api/auth/* routes return 200 not 500.
# trustHost: true is also set in authConfig (config.ts) as the durable code fix.
AUTH_TRUST_HOST=true

# ENCRYPTION (AES-256-GCM for EarthRanger credential column encryption)
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# EMAIL (dev uses MailHog — no real SMTP needed)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=dev@localhost
# SMTP_USER=your-smtp-username (staging/prod only)
# SMTP_PASSWORD=your-smtp-password (staging/prod only)

# PGADMIN
PGADMIN_PORT=5050
PGADMIN_EMAIL=your-pgadmin-email@admin.local
PGADMIN_PASSWORD=your-pgadmin-password-here

# SEED ACCOUNTS (used by pnpm db:seed — re-seed rotates passwords)
WEBMASTER_PASSWORD=your-webmaster-password-here
DEMO_SITE_ADMIN_PASSWORD=your-demo-site-admin-password-here
# DEV-ONLY: set to "true" to seed predictable weak login accounts for local dev
# (admin@mail.com/admin, user@mail.com/user). Leave unset/false in staging+prod.
# SEED_DEV_ACCOUNTS=false

# SMS (scaffolded — not active in v1)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# I18N
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_LOCALES=en,id,ms

# PDF RENDERER (marine-guardian-pdf-renderer — Phase 8 Batch 5 Sub-batch 5.3a)
# Sandboxed Puppeteer + Chromium service for HTML-to-PDF rendering. The
# BullMQ pdf-render worker (5.3b — pending) calls this service over the
# internal Docker network — no host port exposure. Generate the token via
# `openssl rand -base64 64 | tr -d '\n' | head -c 48` per environment.
PDF_RENDERER_SERVICE_URL=http://marine-guardian_dev_pdf_renderer:4000
PDF_RENDERER_SERVICE_TOKEN=your-48-char-pdf-renderer-token-here

# WEB APP INTERNAL URL (consumed by the packages/jobs pdf-render worker — 5.3b)
# Internal Docker hostname the pdf-renderer container navigates to for
# /print-render/[tenantSlug]/[reportType]/[exportId]. Read by BOTH the app and
# the worker service (both load this env file via env_file:). The WORKER is the
# real consumer — the pdf-render processor throws and the report export FAILS if
# this is unset (prod incident 2026-07-06: the worker container was missing it,
# so /exports spun forever on a stuck "queued" row).
# REQUIRED in EVERY environment. Per-env value = http://marine-guardian_<env>_app:3000,
# matching each stack's COMPOSE_PROJECT_NAME (the *_app container hostname):
#   dev     → http://marine-guardian_dev_app:3000
#   staging → http://marine-guardian_staging_app:3000
#   prod    → http://marine-guardian_prod_app:3000
# NOT secret — not in CREDENTIALS.md.
WEB_APP_INTERNAL_URL=http://marine-guardian_dev_app:3000

# R2 photo cache (read-through cache for Telegram event photos — optional).
# Leave R2_CACHE_ENABLED unset/false to serve straight from Telegram (ships dark).
# Real creds live in Server-Setups/Powerbyte-Hostinger/secrets/cloudflare-r2.enc.yaml.
R2_CACHE_ENABLED=false
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_CACHE_BUCKET=marine-guardian-dev-photo-cache

# TELEGRAM STORAGE (report exports + ER photo archiving — Phase 4 S1)
# Report PDFs are delivered SOLELY via Telegram in production: the pdf-render
# worker sends the finished PDF to the tenant's Telegram channel
# (tenant.telegramChannelId — the SAME channel as ER photo archiving, no MinIO
# copy) via sendDocument, and the download route fetches it back by file_id.
# Both the worker AND the web app need TELEGRAM_BOT_TOKEN + a channel id. When a
# tenant has no telegramChannelId, TELEGRAM_DEFAULT_CHANNEL_ID is used; if
# neither is set the worker degrades to the legacy MinIO exports bucket
# (REPORT_EXPORTS_MINIO_FALLBACK, default OFF — not the production path).
# REQUIRED in EVERY environment (dev/staging/prod) — set in the *_app AND worker
# env_file, exactly like WEB_APP_INTERNAL_URL above.
# Real values live in SOPS (NOT in this repo):
#   Server-Setups/Powerbyte-Hostinger/secrets/marine-guardian-telegram.enc.yaml
# (token = @MarineGuardian_bot BotFather credential; channel id = ER archive chat).
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHANNEL_ID=
# Optional mirror: also write report PDFs to MinIO alongside Telegram so the
# store is swappable back without a redeploy. Default OFF.
REPORT_EXPORTS_MINIO_FALLBACK=false
